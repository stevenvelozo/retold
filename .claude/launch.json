{
	"version": "0.0.1",
	"configurations": [
		{
			"name": "docs",
			"runtimeExecutable": "npx",
			"runtimeArgs": ["quack", "docs-serve", "./docs"],
			"port": 3333
		},
		{
			"name": "docuserve-todo-app",
			"runtimeExecutable": "bash",
			"runtimeArgs": ["-c", "cd modules/pict/pict-docuserve && node example_applications/build-examples.js serve todo-app"],
			"port": 3333
		},
		{
			"name": "retold-content-system",
			"runtimeExecutable": "bash",
			"runtimeArgs": ["-c", "cd modules/apps/retold-content-system && PORT=9001 node server.js"],
			"port": 9001
		},
		{
			"name": "retold-remote",
			"runtimeExecutable": "bash",
			"runtimeArgs": ["-c", "cd modules/apps/retold-remote && PORT=9002 node server.js"],
			"port": 9002
		},
		{
			"name": "retold-harness",
			"runtimeExecutable": "bash",
			"runtimeArgs": ["-c", "cd modules/meadow/retold-harness && PORT=9003 node source/Retold-Harness.js"],
			"port": 9003
		},
		{
			"name": "flow-example",
			"runtimeExecutable": "bash",
			"runtimeArgs": ["-c", "cd modules/pict/pict-section-flow/example_applications/simple_cards/dist && python3 -m http.server 9099"],
			"port": 9099
		},
		{
			"name": "data-cloner",
			"runtimeExecutable": "bash",
			"runtimeArgs": ["-c", "cd modules/meadow/retold-data-service/example_applications/data-cloner && node data-cloner.js"],
			"port": 8095
		},
		{
			"name": "ultravisor-webinterface",
			"runtimeExecutable": "bash",
			"runtimeArgs": ["-c", "cd modules/apps/ultravisor/webinterface/dist && python3 -m http.server 9100"],
			"port": 9100
		},
		{
			"name": "ultravisor-dev",
			"runtimeExecutable": "bash",
			"runtimeArgs": ["-c", "cd modules/apps/ultravisor && node source/cli/Ultravisor-Run.cjs start --config .claude/ultravisor-dev-config.json"],
			"port": 54321
		},
		{
			"name": "formeditor-example",
			"runtimeExecutable": "bash",
			"runtimeArgs": ["-c", "cd modules/pict/pict-section-formeditor && npx quack examples -p 9200"],
			"port": 9200
		},
		{
			"name": "graph-explorer",
			"runtimeExecutable": "bash",
			"runtimeArgs": ["-c", "cd modules/meadow/meadow-graph-client/example_applications/graph-explorer && node server.js"],
			"port": 3420
		},
		{
			"name": "login-example",
			"runtimeExecutable": "bash",
			"runtimeArgs": ["-c", "cd modules/orator/orator-authentication/example_applications/simple_login && node Serve-Login-Example.js"],
			"port": 9060
		}
	]
}
