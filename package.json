{
    "name": "retold",
    "version": "4.0.11",
    "description": "The pict and fable node ecosystem.",
    "main": "source/Retold.cjs",
    "bin": {
        "manager": "./source/retold-manager/retold-manager.js"
    },
    "scripts": {
        "start": "node source/Retold.cjs",
        "build-docs": "npx quack prepare-docs ./docs -d ./modules",
        "serve-docs": "npx pict-docuserve serve ./docs -p 3456",
        "audit": "node source/retold-manager/bin/manifest-audit.js",
        "rebuild-modules": "node source/retold-manager/bin/manifest-rebuild-shell.js"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/stevenvelozo/retold.git"
    },
    "keywords": [],
    "author": "Steven Velozo <steven@velozo.com> (http://velozo.com/)",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/stevenvelozo/retold/issues"
    },
    "homepage": "https://github.com/stevenvelozo/retold",
    "devDependencies": {
        "indoctrinate": "^1.0.10",
        "pict-docuserve": "^0.1.5"
    },
    "dependencies": {
        "quackage": "^1.1.2",
        "retold-content-system": "^1.0.21"
    }
}
