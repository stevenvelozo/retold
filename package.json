{
    "name": "retold",
    "version": "4.0.11",
    "description": "The pict and fable node ecosystem.",
    "main": "source/retold-manager.js",
    "bin": {
        "manager": "./source/retold-manager.js"
    },
    "scripts": {
        "start": "node source/retold-manager.js",
        "build-docs": "npx quack prepare-docs ./docs -d ./modules",
        "serve-docs": "npx pict-docuserve serve ./docs -p 3456",
        "audit": "node source/bin/manifest-audit.js",
        "rebuild-modules": "node source/bin/manifest-rebuild-shell.js"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/stevenvelozo/retold.git"
    },
