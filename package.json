    "bugs": {
        "url": "https://github.com/stevenvelozo/retold/issues"
    },
    "homepage": "https://github.com/stevenvelozo/retold",
    "devDependencies": {
        "indoctrinate": "^1.0.10",
        "pict-docuserve": "^0.1.6"
    },
    "dependencies": {
        "@recogito/annotorious-better-polygon": "^0.2.0",
        "@recogito/annotorious-openseadragon": "^2.7.19",
        "@recogito/annotorious-selector-pack": "^0.6.1",
        "pict-section-formeditor": "^1.0.13",
        "pict-section-objecteditor": "^1.0.1",
        "quackage": "^1.2.3",
        "retold-content-system": "^1.0.22"
