{
    "name": "retold",
    "version": "4.0.11",
    "description": "The pict and fable node ecosystem.",
    "main": "source/retold-manager-web.js",
    "bin": {
        "manager": "./source/retold-manager-web.js"
    },
    "scripts": {
        "start": "node source/retold-manager-web.js",
        "build-docs": "npx quack prepare-docs ./docs -d ./modules -g fable-retold",
        "serve-docs": "npx pict-docuserve serve ./docs -p 3456",
        "audit": "node source/bin/manifest-audit.js",
        "rebuild-modules": "node source/bin/manifest-rebuild-shell.js"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/fable-retold/retold.git"
    },
    "keywords": [],
    "author": "Steven Velozo <steven@velozo.com> (http://velozo.com/)",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/fable-retold/retold/issues"
    },
    "homepage": "https://github.com/fable-retold/retold",
    "devDependencies": {
        "indoctrinate": "^1.0.11"
    },
    "dependencies": {
        "fable": "^3.1.73",
        "fable-serviceproviderbase": "^3.0.19",
        "orator": "^6.1.2",
        "orator-serviceserver-restify": "^2.0.11",
        "pict": "^1.0.368",
        "pict-application": "^1.0.34",
        "pict-docuserve": "^1.3.0",
        "pict-router": "^1.0.10",
        "pict-section-content": "^1.0.2",
        "pict-section-filebrowser": "^1.0.4",
        "pict-section-modal": "^1.1.1",
        "pict-section-theme": "^1.0.2",
        "pict-view": "^1.0.68",
        "quackage": "^1.2.3",
        "retold-content-system": "^1.0.25",
        "ws": "^8.20.1"
    }
}
