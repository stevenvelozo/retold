{
	"name": "retold-manager",
	"version": "0.0.1",
	"description": "Terminal UI and web UI manager for retold module repositories",
	"main": "retold-manager.js",
	"bin": {
		"retold-manager": "./retold-manager.js",
		"retold-manager-web": "./retold-manager-web.js"
	},
	"scripts": {
		"start": "node retold-manager.js",
		"web": "node retold-manager-web.js",
		"terminal": "node retold-manager.js --terminal",
		"build": "npx quack build",
		"audit": "node bin/manifest-audit.js",
		"rebuild-shell": "node bin/manifest-rebuild-shell.js",
		"rebuild-shell-check": "node bin/manifest-rebuild-shell.js --check",
		"test": "echo \"No tests yet\" && exit 0"
	},
	"license": "MIT",
	"dependencies": {
		"blessed": "^0.1.81",
		"fable": "^3.0.232",
		"fable-serviceproviderbase": "^3.0.16",
		"orator": "^6.1.0",
		"orator-serviceserver-restify": "^2.0.10",
		"pict": "^1.0.345",
		"pict-application": "^1.0.28",
		"pict-router": "^1.0.9",
		"pict-section-modal": "^0.0.5",
		"pict-terminalui": "^0.0.2",
		"pict-view": "^1.0.64",
		"ws": "^8.20.0"
	},
	"devDependencies": {
		"quackage": "^1.1.2"
	}
}
